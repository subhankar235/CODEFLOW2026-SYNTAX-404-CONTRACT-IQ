uage"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/report/{reportId}":{"get":{"tags":["report"],"summary":"Get Report","description":"Retrieve report details or download the PDF if it exists.","operationId":"get_report_api_v1_report__reportId__get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"reportId","in":"path","required":true,"schema":{"type":"string","format":"uuid","title":"Reportid"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/report/download/{reportId}":{"get":{"tags":["report"],"summary":"Download Report","description":"Internal download link for the authenticated user.","operationId":"download_report_api_v1_report_download__reportId__get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"reportId","in":"path","required":true,"schema":{"type":"string","format":"uuid","title":"Reportid"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/report/share/{shareUuid}":{"get":{"tags":["report"],"summary":"Get Shared Report","description":"Public endpoint to access a report via share UUID.\nChecks for expiry.","operationId":"get_shared_report_api_v1_report_share__shareUuid__get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"shareUuid","in":"path","required":true,"schema":{"type":"string","title":"Shareuuid"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation