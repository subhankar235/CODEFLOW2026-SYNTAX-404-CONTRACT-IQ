# ── Frontend ─────────────────────────────────────────────
# Next.js API URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Clerk publishable key (from Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (from Clerk dashboard)
CLERK_SECRET_KEY=
# Uploadthing secret (from Uploadthing dashboard)
UPLOADTHING_SECRET=
# Uploadthing app ID (from Uploadthing dashboard)
UPLOADTHING_APP_ID=

# ── Backend API ───────────────────────────────────────────
# Neon PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
# Upstash Redis URL (rediss:// for SSL, ?ssl_cert_reqs=none required)
REDIS_URL=rediss://default:password@host:6379?ssl_cert_reqs=none
# Clerk webhook secret (from Clerk dashboard)
CLERK_WEBHOOK_SECRET=
# Clerk JWKS URL (https://<your-clerk-domain>/.well-known/jwks.json)
CLERK_JWKS_URL=

# ── AI Service ───────────────────────────────────────────
# OpenRouter API key (from openrouter.ai)
OPENROUTER_API_KEY=
# Primary model (Llama 3.3 70B)
PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Fast model (Gemini Flash)
FAST_MODEL=google/gemini-2.0-flash-exp:free
# DeepL API key (from deepl.com)
DEEPL_API_KEY=
# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Shared ────────────────────────────────────────────────
# AI Service URL
AI_SERVICE_URL=http://localhost:8001
# Environment (development or production)
ENVIRONMENT=development